import subprocess
import sys

def run_cmd(command):
    """Run a command, print it, then show output."""
    print(f"\n$ {command}\n")
    result = subprocess.run(command, shell=True, text=True, capture_output=True)

    print(result.stdout)
    if result.stderr:
        print("ERROR:", result.stderr)

    return result

def main():
    commit_message = "Auto commit"
    force = False

    args = sys.argv[1:]

    # Get commit message (-m "message")
    if "-m" in args:
        i = args.index("-m")
        if i + 1 < len(args):
            commit_message = args[i + 1]

    # Check for force flag (-f)
    if "-f" in args:
        force = True

    # Step 1: git status
    print("\ngit status:")
    run_cmd("git status")

    # Commands to run
    commands = [
        "git add .",
        f'git commit -m "{commit_message}"',
        "git push"
    ]

    # Show queued commands
    print("\nQueued commands:")
    for c in commands:
        print(c)

    # Ask for confirmation (unless force mode)
    if not force:
        answer = input("\nRun these commands? (y/n): ").lower()
        if answer != "y":
            print("Cancelled.")
            return

    # Run commands
    for c in commands:
        run_cmd(c)

if __name__ == "__main__":
    main()
